import { createClient } from '@supabase/supabase-js';
import * as dotenv from 'dotenv';
dotenv.config({ path: 'd:/Начальник виробництва/.env.local' });

async function run() {
    const supabase = createClient(
        process.env.NEXT_PUBLIC_SUPABASE_URL || '',
        process.env.SUPABASE_SERVICE_ROLE_KEY || ''
    );

    const { data: catalog, error } = await supabase.from('production_catalog').select('product_id, product_name, is_active');
    if (error) {
        console.error("Query Error via normal select:", error.message);
        // Fallback to exec_sql
        const { data: rpcData, error: rpcError } = await supabase.rpc('exec_sql', {
            query: "SELECT product_id, product_name, is_active FROM graviton.production_catalog"
        });
        if (rpcError) console.error("RPC Error:", rpcError);
        else console.log(JSON.stringify(rpcData, null, 2));
    } else {
        console.log(JSON.stringify(catalog, null, 2));
    }
}
run();
